---
import Base from "../layouts/Base.astro";

let success = false;
let error = "";

if (Astro.request.method === "POST") {
	const data = await Astro.request.formData();
	const name = String(data.get("name") ?? "").trim();
	const email = String(data.get("email") ?? "").trim();
	const message = String(data.get("message") ?? "").trim();

	if (!name || !email || !message) {
		error = "All fields are required.";
	} else if (!email.includes("@")) {
		error = "Please enter a valid email address.";
	} else {
		// TODO: wire up email delivery (e.g. via the forms plugin or a webhook)
		console.log("Contact form submission:", { name, email, message });
		success = true;
	}
}
---

<Base title="Contact">
	<div class="contact-page">
		<div class="contact-grid">
			<div class="contact-main">
				<h1 class="contact-title">Contact</h1>

				{success ? (
					<div class="success-message">
						<p>Thanks for reaching out! We'll get back to you soon.</p>
					</div>
				) : (
					<form method="POST" class="contact-form">
						{error && <p class="error-message">{error}</p>}

						<div class="field">
							<label for="name">Name</label>
							<input
								id="name"
								name="name"
								type="text"
								required
								autocomplete="name"
								placeholder="Your name"
							/>
						</div>

						<div class="field">
							<label for="email">Email</label>
							<input
								id="email"
								name="email"
								type="email"
								required
								autocomplete="email"
								placeholder="you@example.com"
							/>
						</div>

						<div class="field">
							<label for="message">Message</label>
							<textarea
								id="message"
								name="message"
								required
								rows="6"
								placeholder="Tell us about your project"
							></textarea>
						</div>

						<button type="submit" class="submit-btn">Send message</button>
					</form>
				)}
			</div>

			<aside class="contact-sidebar">
				<div class="sidebar-section">
					<h2 class="sidebar-heading">Email</h2>
					<p><a href="mailto:hello@example.com">hello@example.com</a></p>
				</div>

				<div class="sidebar-section">
					<h2 class="sidebar-heading">Based in</h2>
					<p>San Francisco, CA</p>
				</div>
			</aside>
		</div>
	</div>
</Base>

<style>
	.contact-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: var(--spacing-16);
		align-items: start;
	}

	.contact-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: var(--font-size-4xl);
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		margin: 0 0 var(--spacing-8);
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-5);
	}

	.field {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	label {
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-text);
	}

	input,
	textarea {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-text);
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		padding: var(--spacing-3) var(--spacing-4);
		transition:
			border-color var(--transition-fast),
			box-shadow var(--transition-fast);
		width: 100%;
	}

	input::placeholder,
	textarea::placeholder {
		color: var(--color-muted);
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px var(--color-accent-ring);
	}

	textarea {
		resize: vertical;
		min-height: 140px;
	}

	.submit-btn {
		align-self: flex-start;
		padding: var(--spacing-3) var(--spacing-8);
		background: var(--color-text);
		color: var(--color-bg);
		border: none;
		border-radius: var(--radius);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		cursor: pointer;
		transition: opacity var(--transition-fast);
	}

	.submit-btn:hover {
		opacity: 0.8;
	}

	.success-message {
		padding: var(--spacing-6);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
	}

	.error-message {
		padding: var(--spacing-3) var(--spacing-4);
		background: #fff0f0;
		color: #cc0000;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		margin: 0;
	}

	.contact-sidebar {
		position: sticky;
		top: calc(var(--nav-height, 64px) + var(--spacing-8));
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
		padding-top: calc(var(--font-size-4xl) + var(--spacing-8));
	}

	.sidebar-heading {
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin: 0 0 var(--spacing-3);
	}

	.sidebar-section p {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (max-width: 768px) {
		.contact-page {
			padding: var(--spacing-10) var(--spacing-4);
		}

		.contact-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
		}

		.contact-sidebar {
			position: static;
			padding-top: 0;
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: var(--spacing-6);
		}

		.contact-title {
			font-size: var(--font-size-3xl);
		}
	}

	@media (max-width: 480px) {
		.contact-sidebar {
			grid-template-columns: 1fr;
		}
	}
</style>
