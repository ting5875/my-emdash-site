---
import { getEmDashCollection, getTermsForEntries, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";

const [{ entries: projects, cacheHint }, settings] = await Promise.all([
	getEmDashCollection("projects", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
	getSiteSettings(),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const siteTitle = settings?.title ?? "Studio";
const siteTagline = settings?.tagline ?? "Design and creative direction";

const projectIds = projects.map((p) => p.data.id);
const tagsByEntry = projectIds.length
	? await getTermsForEntries("projects", projectIds, "tag")
	: new Map();
---

<Base title={siteTitle} description={siteTagline}>
	<section class="hero">
		<div class="hero-inner">
			<h1 class="hero-title">{siteTitle}</h1>
			<p class="hero-tagline">{siteTagline}</p>
		</div>
	</section>

	<section class="work-section">
		<div class="work-inner">
			<header class="section-header">
				<h2 class="section-label">Selected Work</h2>
				{projects.length > 0 && (
					<a href="/work" class="section-link">View all</a>
				)}
			</header>

			{projects.length === 0 ? (
				<div class="empty-state">
					<p>No projects yet.</p>
					<a href="/_emdash/admin/content/projects/new" class="btn">
						Add your first project
					</a>
				</div>
			) : (
				<div class="projects-grid">
					{projects.map((project) => {
						const tags = (tagsByEntry.get(project.data.id) ?? []).map((t) => ({
							slug: t.slug,
							label: t.label,
						}));
						return (
							<ProjectCard
								title={project.data.title ?? "Untitled"}
								summary={project.data.summary}
								featuredImage={project.data.featured_image}
								href={`/work/${project.id}`}
								client={project.data.client}
								year={project.data.year}
								tags={tags}
							/>
						);
					})}
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	.hero {
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.hero-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-20) var(--spacing-6);
	}

	.hero-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: clamp(var(--font-size-4xl), 8vw, var(--font-size-5xl));
		font-weight: 400;
		letter-spacing: var(--tracking-tight);
		line-height: var(--leading-tight);
		color: var(--color-text);
		margin: 0 0 var(--spacing-4);
	}

	.hero-tagline {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		margin: 0;
		max-width: 480px;
	}

	.work-section {
		padding: var(--spacing-16) 0;
	}

	.work-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-6);
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.section-label {
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.section-link {
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.section-link:hover {
		color: var(--color-accent-hover);
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-12) var(--spacing-8);
	}

	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-4);
		text-align: center;
		padding: var(--spacing-20) 0;
		color: var(--color-muted);
	}

	.btn {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-size: var(--font-size-sm);
		font-weight: 500;
		transition: background var(--transition-fast);
	}

	.btn:hover {
		background: var(--color-accent-hover);
	}

	@media (max-width: 768px) {
		.hero-inner {
			padding: var(--spacing-12) var(--spacing-4);
		}

		.projects-grid {
			grid-template-columns: 1fr;
			gap: var(--spacing-10);
		}

		.work-inner {
			padding: 0 var(--spacing-4);
		}
	}
</style>
