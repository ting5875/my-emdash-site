---
import { Image } from "emdash/ui";

interface Props {
	title: string;
	summary?: string | null;
	featuredImage?: { src?: string; alt?: string } | null;
	href: string;
	client?: string | null;
	year?: string | null;
	tags?: { slug: string; label: string }[];
}

const { title, summary, featuredImage, href, client, year, tags = [] } = Astro.props;
const meta = [client, year].filter(Boolean).join(", ");
---

<article class="project-card">
	<a href={href} class="card-link">
		<div class="card-image">
			{featuredImage
				? <Image image={featuredImage} />
				: <div class="card-image-placeholder" />
			}
			<div class="card-overlay">
				<span class="card-cta">View Project</span>
			</div>
		</div>
		<div class="card-body">
			{meta && <p class="card-meta">{meta}</p>}
			<h2 class="card-title">{title}</h2>
			{summary && <p class="card-summary">{summary}</p>}
			{tags.length > 0 && (
				<div class="card-tags">
					{tags.map((tag) => (
						<span class="card-tag">{tag.label}</span>
					))}
				</div>
			)}
		</div>
	</a>
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
	}

	.card-link {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
	}

	.card-image {
		position: relative;
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--color-surface);
		border-radius: var(--radius-lg);
	}

	.card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}

	.card-image-placeholder {
		width: 100%;
		height: 100%;
		background: var(--color-surface);
	}

	.card-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity var(--transition-base);
	}

	.card-cta {
		color: white;
		font-size: var(--font-size-sm);
		font-weight: 500;
		letter-spacing: var(--tracking-wide);
		text-transform: uppercase;
		transform: translateY(6px);
		transition: transform var(--transition-base);
	}

	.card-link:hover .card-image :global(img) {
		transform: scale(1.03);
	}

	.card-link:hover .card-overlay {
		opacity: 1;
	}

	.card-link:hover .card-cta {
		transform: translateY(0);
	}

	.card-body {
		padding: var(--spacing-4) 0 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-1);
	}

	.card-meta {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		margin: 0;
	}

	.card-title {
		font-family: var(--font-serif, var(--font-sans));
		font-size: var(--font-size-xl);
		font-weight: 500;
		line-height: var(--leading-snug);
		letter-spacing: var(--tracking-snug);
		color: var(--color-text);
		margin: 0;
		transition: color var(--transition-fast);
	}

	.card-link:hover .card-title {
		color: var(--color-accent);
	}

	.card-summary {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		line-height: var(--leading-relaxed);
		margin: var(--spacing-1) 0 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-2);
	}

	.card-tag {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
	}

	.card-tag + .card-tag::before {
		content: "·";
		margin-right: var(--spacing-2);
	}
</style>
