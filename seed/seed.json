{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Portfolio Starter",
		"description": "A portfolio with projects and pages",
		"author": "EmDash"
	},
	"settings": {
		"title": "Studio",
		"tagline": "Design and creative direction"
	},
	"collections": [
		{
			"slug": "projects",
			"label": "Projects",
			"labelSingular": "Project",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "featured_image",
					"label": "Featured Image",
					"type": "image"
				},
				{
					"slug": "summary",
					"label": "Summary",
					"type": "text",
					"searchable": true
				},
				{
					"slug": "client",
					"label": "Client",
					"type": "string"
				},
				{
					"slug": "year",
					"label": "Year",
					"type": "string"
				},
				{
					"slug": "live_url",
					"label": "Live URL",
					"type": "string"
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		}
	],
	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": false,
			"collections": ["projects"],
			"terms": [
				{ "slug": "branding", "label": "Branding" },
				{ "slug": "web-design", "label": "Web Design" },
				{ "slug": "print", "label": "Print" },
				{ "slug": "photography", "label": "Photography" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["projects"],
			"terms": [
				{ "slug": "identity", "label": "Identity" },
				{ "slug": "ui-ux", "label": "UI/UX" },
				{ "slug": "development", "label": "Development" },
				{ "slug": "art-direction", "label": "Art Direction" },
				{ "slug": "packaging", "label": "Packaging" },
				{ "slug": "e-commerce", "label": "E-commerce" },
				{ "slug": "editorial", "label": "Editorial" }
			]
		}
	],
	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Work", "url": "/work" },
				{ "type": "custom", "label": "About", "url": "/about" },
				{ "type": "custom", "label": "Contact", "url": "/contact" }
			]
		}
	],
	"content": {
		"pages": [
			{
				"id": "about",
				"slug": "about",
				"status": "published",
				"data": {
					"title": "About",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "We are a small design studio established in 2020, specialising in brand identity, web design, and art direction. We work with founders, cultural institutions, and companies who care about how they present themselves to the world.",
									"_key": "k1"
								}
							],
							"_key": "k0"
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Our process is collaborative and unhurried. We take on a small number of projects at a time so each one gets the attention it deserves.",
									"_key": "k3"
								}
							],
							"_key": "k2"
						}
					]
				}
			}
		],
		"projects": [
			{
				"id": "project-meridian",
				"slug": "meridian",
				"status": "published",
				"data": {
					"title": "Meridian",
					"client": "Meridian Collective",
					"year": "2024",
					"summary": "A brand identity for a creative collective bridging artists and technologists.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&h=900&fit=crop",
							"alt": "Meridian brand identity",
							"filename": "meridian-hero.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Meridian came to us with a clear brief: create an identity that felt rigorous and artistic at the same time. The result is a system built around a single geometric mark that reads differently at different scales.",
									"_key": "k1"
								}
							],
							"_key": "k0"
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "The colour palette draws from nautical charts — navy, sand, and a single warm red — grounding the brand in something physical while leaving room for the digital work the collective produces.",
									"_key": "k3"
								}
							],
							"_key": "k2"
						}
					]
				},
				"taxonomies": {
					"category": ["branding"],
					"tag": ["identity", "art-direction"]
				}
			},
			{
				"id": "project-volta",
				"slug": "volta",
				"status": "published",
				"data": {
					"title": "Volta",
					"client": "Volta Energy",
					"year": "2024",
					"summary": "Website design for an energy startup making clean power accessible to everyone.",
					"live_url": "https://example.com",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1497436072909-60f360e1d4b1?w=1200&h=900&fit=crop",
							"alt": "Volta website design",
							"filename": "volta-hero.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Volta needed a site that could explain a complex product to two very different audiences: homeowners curious about solar, and investors looking at the business case. We designed around that tension.",
									"_key": "k1"
								}
							],
							"_key": "k0"
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "The information architecture separates the two journeys cleanly while sharing a visual language: clean data visualisations, honest photography, and a confident typographic system that avoids the greenwashing tropes common in the sector.",
									"_key": "k3"
								}
							],
							"_key": "k2"
						}
					]
				},
				"taxonomies": {
					"category": ["web-design"],
					"tag": ["ui-ux", "development"]
				}
			},
			{
				"id": "project-archive",
				"slug": "the-archive",
				"status": "published",
				"data": {
					"title": "The Archive",
					"client": "Museum of Modern Architecture",
					"year": "2023",
					"summary": "Exhibition catalogue for a modernist architecture retrospective.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1200&h=900&fit=crop",
							"alt": "The Archive exhibition catalogue",
							"filename": "archive-hero.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "A 240-page catalogue designed to accompany a retrospective on mid-century modernist architecture. The constraint was deliberate: no colour photography, only archival black-and-white images shot on site between 1952 and 1971.",
									"_key": "k1"
								}
							],
							"_key": "k0"
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Typography became the primary design element. We set the body in a digitised version of the typeface the original architects used in their drawings, creating continuity between the buildings and the book.",
									"_key": "k3"
								}
							],
							"_key": "k2"
						}
					]
				},
				"taxonomies": {
					"category": ["print"],
					"tag": ["editorial", "art-direction"]
				}
			},
			{
				"id": "project-coastal",
				"slug": "coastal",
				"status": "published",
				"data": {
					"title": "Coastal",
					"client": "Personal project",
					"year": "2023",
					"summary": "A photographic series shot on medium format film exploring the Pacific coastline.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1200&h=900&fit=crop",
							"alt": "Coastal photography series",
							"filename": "coastal-hero.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Forty images shot over three months along the Pacific coast, from the Oregon border to Baja California. The brief was self-assigned: document the edge where the continent ends, before it changes.",
									"_key": "k1"
								}
							],
							"_key": "k0"
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Shot entirely on medium format film, developed and scanned by hand. The grain is intentional. So is the decision not to crop.",
									"_key": "k3"
								}
							],
							"_key": "k2"
						}
					]
				},
				"taxonomies": {
					"category": ["photography"],
					"tag": ["art-direction"]
				}
			}
		]
	}
}
